---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import WorksCarousel from '../components/WorksCarousel.astro';
import Services from '../components/Services.astro';
import Expertise from '../components/Expertise.astro';
import ReportsEmbed from '../components/ReportsEmbed.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header />
  <section id="hero">
    <Hero />
  </section>
  <TrustBar />
  <WorksCarousel />
  <Services />
  <Expertise />
  <ReportsEmbed />
  <!-- #contact is intentionally excluded from scroll-animate.
       The Cal.com embed must initialize inside a visible (non-zero opacity)
       container or it renders with zero dimensions. -->
  <Contact />
  <Footer />
</Layout>

<script>
  /**
   * Scroll-reveal: attaches .scroll-animate to all <section> elements
   * EXCEPT #hero (above fold) and #contact (Cal.com embed constraint).
   * CSS for .scroll-animate and .is-visible lives in Layout.astro global styles.
   * Respects prefers-reduced-motion via the CSS rule (no JS check needed).
   */
  (function () {
    const EXCLUDED = new Set(['hero', 'contact']);

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll<HTMLElement>('section').forEach((section) => {
      if (EXCLUDED.has(section.id)) return;
      section.classList.add('scroll-animate');
      observer.observe(section);
    });

    // Smooth anchor scroll with header offset
    document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener('click', (e) => {
        const targetId = anchor.getAttribute('href')?.slice(1);
        if (!targetId) return;
        const target = document.getElementById(targetId);
        if (!target) return;
        e.preventDefault();
        const headerOffset = 80;
        const elementPosition = target.getBoundingClientRect().top + window.scrollY;
        window.scrollTo({ top: elementPosition - headerOffset, behavior: 'smooth' });
      });
    });
  })();
</script>
