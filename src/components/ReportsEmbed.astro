---
// Reports Embed Component - Conditional Evidence.dev iframe
import { site } from '../data/site.ts';
---

{site.reportsURL && (
<section class="py-20 md:py-32 bg-neutral-900/20">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <div class="mb-8">
      <h2 class="text-3xl md:text-4xl font-bold text-neutral-100 mb-2">Performance Insights</h2>
      <p class="text-neutral-400">Live operational data and industry benchmarks.</p>
    </div>
    <div class="rounded-xl overflow-hidden border border-neutral-800 bg-neutral-900/50" style="height: 680px;">
      <iframe
        src={site.reportsURL}
        title="Streamline IT Performance Reports"
        width="100%"
        height="100%"
        style="border: none;"
        loading="lazy"
        sandbox="allow-scripts allow-same-origin allow-forms"
      ></iframe>
    </div>
    <p class="text-xs text-neutral-500 mt-3 text-right">
      <a href={site.reportsURL} target="_blank" rel="noopener noreferrer" class="hover:text-primary-400 transition-colors">
        Open full report ↗
      </a>
    </p>
  </div>
</section>
)}