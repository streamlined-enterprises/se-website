---
// Contact Section Component with Cal.com inline embed
import { site } from '../data/site.ts';
---

<section id="contact" class="py-20 md:py-32 bg-surface/30">
  <div class="max-w-2xl mx-auto px-4 md:px-6">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-content-base mb-4">
        {site.contactTitle}
      </h2>
      <p class="text-content-muted text-lg">
        {site.contactDescription}
      </p>
    </div>
    
    {site.calLink ? (
      <!-- Cal.com Inline Embed -->
      <div 
        id="cal-embed" 
        data-cal-link={site.calLink}
        style="width:100%;min-height:600px;"
      ></div>
      
      <script>
        (function (C, A, L) {
          let p = function (a, ar) { a.q.push(ar); };
          let d = C.document;
          C.Cal = C.Cal || function () {
            let cal = C.Cal;
            let ar = arguments;
            if (!cal.loaded) {
              cal.ns = {};
              cal.q = cal.q || [];
              d.head.appendChild(d.createElement("script")).src = A;
              cal.loaded = true;
            }
            if (ar[0] === L) {
              const api = function () { p(api, arguments); };
              const namespace = ar[1];
              api.q = api.q || [];
              if (typeof namespace === "string") {
                cal.ns[namespace] = cal.ns[namespace] || api;
                p(cal.ns[namespace], ar);
                p(cal, ["-", namespace, api]);
              } else {
                p(cal, ar);
                p(cal, ["-", ar[1], api]);
              }
              return;
            }
            p(cal, ar);
          };
        })(window, "https://app.cal.com/embed/embed.js", "init");

        Cal("init", { origin: "https://cal.com" });

        const calEmbed = document.getElementById('cal-embed');
        const calLink = calEmbed && calEmbed.dataset.calLink;

        if (calLink) {
          Cal("inline", {
            elementOrSelector: "#cal-embed",
            calLink: calLink,
            layout: "month"
          });

          Cal("ui", {
            theme: "dark",
            cssVarsPerTheme: {
              dark: { "cal-brand": "#14b8a6" }
            },
            hideEventTypeDetails: false,
            layout: "month"
          });
        }
      </script>
    ) : (
      <!-- Fallback Placeholder -->
      <div class="backdrop-blur-md bg-surface/50 border border-border-subtle rounded-brand p-12 text-center">
        <p class="text-content-muted mb-4">Online booking coming soon.</p>
        <a 
          href={`mailto:${site.email}`} 
          class="text-primary-400 hover:text-primary-500 transition-colors underline underline-offset-4"
        >
          {site.email}
        </a>
      </div>
    )}
  </div>
</section>
