---
// Trust Bar Component
import { site } from '../data/site.ts';

const iconMap: Record<string, { path: string }> = {
  clock: { path: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" },
  shield: { path: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" },
  building: { path: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" },
};
---

<section class="py-8 md:py-12 bg-slate-900/30 border-y border-slate-800/50">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <div class="flex flex-wrap justify-center gap-8 md:gap-16 text-center">
      {site.trustStats.map((stat, index) => (
        <>
          {index > 0 && <div class="hidden md:block w-px h-12 bg-slate-800"></div>}
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6 text-teal-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconMap[stat.icon]?.path || iconMap.clock.path} />
            </svg>
            <div class="text-left">
              <p class="text-2xl font-bold text-slate-100">{stat.value}</p>
              <p class="text-sm text-slate-400">{stat.label}</p>
            </div>
          </div>
        </>
      ))}
    </div>
  </div>
</section>
