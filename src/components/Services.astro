---
import { getCollection } from 'astro:content';
import { site } from '../data/site.ts';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const featuredServices = services.filter(s => s.data.featured);
const secondaryServices = services.filter(s => !s.data.featured);

const iconMap: Record<string, string> = {
  ai: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z",
  shield: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  cloud: "M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z",
  fractional: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.519-1.188-1.173-1.414M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.519-1.188 1.173-1.414M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
  assessment: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 011-2h2a2 2 0 012 2m-6 9l2 2 4-4",
};
---

<section id="services" class="py-20 md:py-32">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-slate-100 mb-4">
        Services
      </h2>
      <p class="text-slate-400 text-lg md:text-xl max-w-2xl mx-auto">
        Strategic technology leadership for companies at critical inflection points.
      </p>
    </div>
    
    <!-- Featured Services: Asymmetric Grid -->
    {featuredServices.length > 0 && (
      <div class="grid gap-6 mb-6">
        <!-- First featured card: full-width -->
        <article class="group backdrop-blur-md bg-slate-900/50 border border-slate-800 rounded-xl p-8 hover:border-teal-500/50 hover:shadow-lg hover:shadow-teal-500/10 transition-all duration-300 hover:-translate-y-1">
          <div class="mb-6">
            <svg class="w-8 h-8 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconMap[featuredServices[0].data.icon]} />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-slate-100 mb-3 group-hover:text-teal-400 transition-colors">
            {featuredServices[0].data.title}
          </h3>
          <div class="text-slate-400 leading-relaxed">
            <p>{featuredServices[0].body}</p>
          </div>
        </article>
      </div>
    )}
    
    {featuredServices.length > 1 && (
      <div class="grid md:grid-cols-2 gap-6 mb-16">
        {featuredServices.slice(1).map(service => (
          <article class="group backdrop-blur-md bg-slate-900/50 border border-slate-800 rounded-xl p-8 hover:border-teal-500/50 hover:shadow-lg hover:shadow-teal-500/10 transition-all duration-300 hover:-translate-y-1">
            <div class="mb-6">
              <svg class="w-8 h-8 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconMap[service.data.icon]} />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-slate-100 mb-3 group-hover:text-teal-400 transition-colors">
              {service.data.title}
            </h3>
            <div class="text-slate-400 leading-relaxed">
              <p>{service.body}</p>
            </div>
          </article>
        ))}
      </div>
    )}
    
    <!-- Secondary Services Grid -->
    {secondaryServices.length > 0 && (
      <div class="grid md:grid-cols-2 gap-6">
        {secondaryServices.map(service => (
          <article class="backdrop-blur-sm bg-slate-900/30 border border-slate-800 rounded-lg p-6 hover:border-teal-500/30 transition-all duration-300">
            <h3 class="text-lg font-semibold text-slate-100 mb-2">
              {service.data.title}
            </h3>
            <div class="text-slate-400">
              <p>{service.body}</p>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</section>
