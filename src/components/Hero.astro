---
// Hero Section Component
import { site } from '../data/site.ts';
---

<section id="hero" class="min-h-screen flex items-center justify-center relative pt-16 md:pt-20">
  <div class="max-w-6xl mx-auto px-4 md:px-6 text-center">
    <!-- Eyebrow -->
    <p class="text-sm uppercase tracking-wide text-primary-400 mb-4 animate-fade-in">
      {site.heroEyebrow || site.name}
    </p>
    
    <!-- Main Headline -->
    <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-tight -tracking-tight mb-6 animate-slide-up">
      <span class="text-content-base">{site.tagline}</span>
      <br />
      <span class="text-primary-400">{site.taglineSub}</span>
    </h1>
    
    <!-- Subheadline -->
    <p class="text-xl md:text-2xl text-content-muted leading-relaxed max-w-4xl mx-auto mb-10 animate-slide-up" style="animation-delay: 0.2s;">
      {site.heroCopy}
    </p>
    
    <!-- CTA Button Group -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center animate-slide-up" style="animation-delay: 0.4s;">
      <a
        href="#contact"
        class="inline-flex items-center justify-center bg-primary-500 hover:bg-primary-400 text-surface font-semibold px-8 py-4 rounded-lg shadow-lg hover:shadow-primary-500/50 transition-all duration-300 hover:-translate-y-1"
      >
        {site.heroPrimaryCTA}
      </a>
      <a
        href="#services"
        class="inline-flex items-center justify-center border border-border-subtle hover:border-primary-500 text-content-base hover:text-primary-400 px-8 py-4 rounded-lg transition-all duration-300 hover:-translate-y-1"
      >
        {site.heroSecondaryCTA}
      </a>
    </div>
    
    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce-subtle">
      <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>
