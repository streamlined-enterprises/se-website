---
import { site } from '../data/site.ts';
import { theme } from '../data/theme.ts';

interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string;
}

const {
  title = `${site.legalName} | ${site.tagline}`,
  description = site.description,
  canonicalURL = site.canonicalURL
} = Astro.props;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": site.legalName,
  "description": "Secure AI, cloud, and engineering consulting specializing in AI enablement under compliance constraints.",
  "url": site.canonicalURL,
  "priceRange": "$$$",
  "areaServed": {
    "@type": "Place",
    "name": "United States"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": null,
    "contactType": "technical support",
    "availableLanguage": "English"
  },
  "founder": {
    "@type": "Person",
    "jobTitle": "Lead AI & Security Strategist"
  }
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="AI strategy, security consulting, cloud infrastructure, FinTech, PCI compliance, SOC audit, CTO services, enterprise technology, digital transformation" />
    <meta name="author" content="Streamlined Enterprises LLC" />
    <meta name="robots" content="index, follow" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={site.ogImage} />
    <meta property="og:site_name" content={site.legalName} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={site.ogImage} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Preconnect to external resources -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={theme.fontCDNUrl} rel="stylesheet" />
    
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    
    <!-- Skip to main content for accessibility -->
    <style>
      .skip-link {
        position: absolute;
        top: -40px;
        left: 0;
        background: #14B8A6;
        color: #0f172a;
        padding: 8px 16px;
        z-index: 100;
        transition: top 0.3s;
      }
      .skip-link:focus {
        top: 0;
      }
    </style>
  </head>
  <body class="bg-neutral-950 text-neutral-100 font-sans antialiased">
    <!-- Skip to main content link -->
    <a href="#main-content" class="skip-link">Skip to main content</a>
    
    <!-- Radial gradient background overlay -->
    <div class="fixed inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-neutral-900 via-neutral-950 to-neutral-950 pointer-events-none z-0"></div>
    
    <!-- Main content -->
    <main id="main-content" class="relative z-10">
      <slot />
    </main>
    
    <!-- Footer is included in the page -->
  </body>
</html>

<style is:global>
  /* Custom scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
  }
  
  ::-webkit-scrollbar-track {
    /* Sync with neutral-950: #020617 */
    background: #020617;
  }
  
  ::-webkit-scrollbar-thumb {
    /* Sync with neutral-700: #334155 */
    background: #334155;
    border-radius: 4px;
  }
  
  ::-webkit-scrollbar-thumb:hover {
    /* Sync with neutral-600: #475569 */
    background: #475569;
  }
  
  /* Selection color */
  ::selection {
    /* Sync with primary-500: #14B8A6 */
    background: #14B8A6;
    color: #020617;
  }
  
  /* Focus visible styles */
  :focus-visible {
    /* Sync with primary-500: #14B8A6 */
    outline: 2px solid #14B8A6;
    outline-offset: 2px;
  }
</style>
