---
import { site } from '../data/site.ts';
import { theme } from '../data/theme.ts';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string;
}

const {
  title = `${site.legalName} | ${site.tagline}`,
  description = site.description,
  canonicalURL = site.canonicalURL
} = Astro.props;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": site.legalName,
  "description": site.description,
  "url": site.canonicalURL,
  "priceRange": "$$$",
  "email": site.email,
  "areaServed": {
    "@type": "Place",
    "name": "United States"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Kansas City",
    "addressRegion": "MO",
    "addressCountry": "US"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "sales",
    "email": site.email,
    "availableLanguage": "English"
  },
  "founder": {
    "@type": "Person",
    "name": "Ty Stackhouse",
    "jobTitle": "Founder & Lead AI Security Strategist"
  },
  "knowsAbout": ["AI Governance", "Cybersecurity", "Cloud Infrastructure", "PCI Compliance", "SOC Audits", "Fractional CTO"]
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="AI strategy, security consulting, cloud infrastructure, FinTech, PCI compliance, SOC audit, CTO services, enterprise technology, digital transformation" />
    <meta name="author" content={site.legalName} />
    <meta name="robots" content="index, follow" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={site.ogImage} />
    <meta property="og:site_name" content={site.legalName} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={site.ogImage} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Preconnect to external resources -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={theme.fontCDNUrl} rel="stylesheet" />
    
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    
    <!-- Skip to main content for accessibility -->
    <style>
      /*
       * NOTE: theme() CSS-in-JS calls do NOT work inside Astro <style> blocks —
       * they are processed by a separate Vite pipeline. Use raw hex or CSS
       * custom properties here. Values below match:
       *   primary-500  = teal-500  = #14b8a6
       *   neutral-950  = slate-950 = #020617
       */
      .skip-link {
        position: absolute;
        top: -40px;
        left: 0;
        background: #14b8a6;
        color: #020617;
        padding: 8px 16px;
        z-index: 100;
        transition: top 0.3s;
        font-weight: 600;
        text-decoration: none;
        border-radius: 0 0 4px 0;
      }
      .skip-link:focus {
        top: 0;
      }
    </style>
  </head>
  <body class="bg-surface text-content-base font-sans antialiased">
    <!-- Skip to main content link -->
    <a href="#main-content" class="skip-link">Skip to main content</a>
    
    <!-- Radial gradient background overlay -->
    <div class="fixed inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-surface-subtle via-surface to-surface pointer-events-none z-0" aria-hidden="true"></div>
    
    <!-- Main content -->
    <main id="main-content" class="relative z-10">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  /*
   * NOTE: theme() does not work in is:global Astro style blocks for the same
   * reason as above. Raw hex values used. Tailwind utility classes in templates
   * are unaffected.
   */

  /* Custom scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
  }
  
  ::-webkit-scrollbar-track {
    background: #020617; /* slate-950 */
  }
  
  ::-webkit-scrollbar-thumb {
    background: #334155; /* slate-700 */
    border-radius: 4px;
  }
  
  ::-webkit-scrollbar-thumb:hover {
    background: #475569; /* slate-600 */
  }
  
  ::selection {
    background: #14b8a6; /* teal-500 */
    color: #020617;      /* slate-950 */
  }
  
  :focus-visible {
    outline: 2px solid #14b8a6; /* teal-500 */
    outline-offset: 2px;
  }

  /* Scroll-reveal animation — applied by IntersectionObserver in index.astro.
     Excluded from #hero (above fold) and #contact (Cal embed needs a visible
     container at init time or it renders at zero dimensions). */
  .scroll-animate {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.55s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .scroll-animate.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-animate,
    .scroll-animate.is-visible {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
